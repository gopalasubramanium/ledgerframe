# ============================================================================
# LedgerFrame configuration — copy to `.env` and edit. NEVER commit `.env`.
# All values shown are safe defaults for a local, demo-mode install.
#
# IMPORTANT: keep comments on their OWN lines. Do NOT put a trailing comment
# after a value (e.g. `KEY=value  # note`) — systemd's EnvironmentFile would
# treat the comment as part of the value and the app would fail to start.
# ============================================================================

# --- Core ---
LEDGERFRAME_ENV=production
# USB NVMe mount; all mutable data lives here
LEDGERFRAME_DATA_DIR=/mnt/ledgerframe-data
# localhost-only by default. Change ONLY with auth.
LEDGERFRAME_API_HOST=127.0.0.1
LEDGERFRAME_API_PORT=8321
LEDGERFRAME_LOG_LEVEL=INFO

# --- Security ---
# A long random string used to sign session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
LEDGERFRAME_SECRET_KEY=change-me-to-a-long-random-string
# Set to true to allow access from other devices on the LAN. Requires a PIN.
LEDGERFRAME_ALLOW_LAN=false
# Auto-lock the UI after this many minutes of inactivity (0 disables).
LEDGERFRAME_AUTOLOCK_MINUTES=15

# --- Base currency & display ---
# One of: SGD USD INR EUR GBP JPY AUD CNY HKD
LEDGERFRAME_BASE_CURRENCY=SGD
LEDGERFRAME_TIMEZONE=Asia/Singapore

# --- Market data provider ---
# mock = synthetic DEMO data (no key needed). csv = local OHLCV files.
# Set to an external adapter name (e.g. "alphavantage") only after reviewing its licence.
LEDGERFRAME_MARKET_PROVIDER=mock
# Mark quotes stale after this many seconds.
LEDGERFRAME_STALE_AFTER_SECONDS=900
# External provider key (only used when the provider is an external adapter,
# e.g. alphavantage or eodhd).
LEDGERFRAME_MARKET_API_KEY=
# Zerodha Kite (read-only market data), when LEDGERFRAME_MARKET_PROVIDER=kite.
# Two values; the access token is regenerated daily via your own Kite login.
# Stored in env/.env ONLY — never the database.
LEDGERFRAME_KITE_API_KEY=
LEDGERFRAME_KITE_ACCESS_TOKEN=

# --- AI (Hailo) ---
# false disables AI entirely (deterministic fallback still answers with facts).
LEDGERFRAME_AI_ENABLED=true
# hailo | disabled | openai_compatible
LEDGERFRAME_AI_PROVIDER=hailo
LEDGERFRAME_HAILO_BASE_URL=http://127.0.0.1:8000
# Blank = auto-select the smallest supported instruct model.
LEDGERFRAME_AI_MODEL=
LEDGERFRAME_AI_TIMEOUT_SECONDS=30
LEDGERFRAME_AI_MAX_REQUESTS_PER_MINUTE=20
# OpenAI-compatible provider (DISABLED unless set; sends data off-device!).
LEDGERFRAME_OPENAI_BASE_URL=
LEDGERFRAME_OPENAI_API_KEY=

# --- Voice (optional, off by default) ---
LEDGERFRAME_VOICE_ENABLED=false
# whispercpp | vosk | disabled
LEDGERFRAME_STT_PROVIDER=whispercpp
# piper | disabled
LEDGERFRAME_TTS_PROVIDER=piper
LEDGERFRAME_WAKEWORD_ENABLED=false

# --- Backups ---
LEDGERFRAME_BACKUP_ENABLED=true
# Rotate: keep this many encrypted backups.
LEDGERFRAME_BACKUP_KEEP=14
# Recipient public key for age encryption (generate with: age-keygen -o age-identity.txt).
LEDGERFRAME_BACKUP_AGE_RECIPIENT=

# --- Display / kiosk ---
LEDGERFRAME_KIOSK_URL=http://127.0.0.1:8321
LEDGERFRAME_ROTATION_DEFAULT_SECONDS=30
