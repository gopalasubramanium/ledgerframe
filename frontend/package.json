{
  "name": "ledgerframe-frontend",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "description": "LedgerFrame v2 frontend \u2014 design system + component library (from-scratch, ADR-0002).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:tokens": "node scripts/check-design-tokens.mjs",
    "check:copy": "node scripts/check-internal-copy.mjs",
    "check:smoke-isolation": "node scripts/check-smoke-isolation.mjs",
    "test:overflow": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run check:tokens && npm run check:copy && npm run check:smoke-isolation && npm run test && npm run test:overflow"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^7.0.0",
    "vitest": "^3.1.0"
  }
}
